{
  "name": "@buckleyrobinson/buck-workflow",
  "version": "0.2.0",
  "description": "Buck workflow for structured AI-assisted development — plan, build, review, save with durable context management",
  "bin": {
    "buck-workflow": "./scripts/install.mjs"
  },
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "license": "MIT",
  "pi": {
    "extensions": [
      "./extensions/index.ts"
    ],
    "prompts": [
      "./prompts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "omp": {
    "extensions": [
      "./extensions/index.ts"
    ]
  },
  "dependencies": {
    "xstate": "^5.0.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:debug": "npx playwright test --debug",
    "test:e2e:chromium": "npx playwright test --project=chromium",
    "playwright": "playwright",
    "playwright:install": "playwright install chromium",
    "playwright:report": "npx playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
