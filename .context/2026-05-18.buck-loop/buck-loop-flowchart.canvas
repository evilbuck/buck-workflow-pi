    { "id": "e00007", "fromNode": "a1b2c3d4e5f60007", "fromSide": "right", "toNode": "a1b2c3d4e5f60008", "toSide": "left", "label": "Yes", "toEnd": "arrow" },
    { "id": "e00008", "fromNode": "a1b2c3d4e5f60008", "fromSide": "left", "toNode": "a1b2c3d4e5f60003", "toSide": "right", "label": "Yes → Next phase", "toEnd": "arrow" },
    { "id": "e00009", "fromNode": "a1b2c3d4e5f60008", "fromSide": "right", "toNode": "a1b2c3d4e5f60011", "toSide": "left", "label": "No → Done", "toEnd": "arrow" },
    { "id": "e00010", "fromNode": "a1b2c3d4e5f60006", "fromSide": "bottom", "toNode": "a1b2c3d4e5f60009", "toSide": "top", "label": "Stagnation check (parallel)", "toEnd": "arrow" },
    { "id": "e00011", "fromNode": "a1b2c3d4e5f60009", "fromSide": "bottom", "toNode": "a1b2c3d4e5f60010", "toSide": "top", "label": "Yes", "toEnd": "arrow" },
    { "id": "e00012", "fromNode": "a1b2c3d4e5f60009", "fromSide": "left", "toNode": "a1b2c3d4e5f60004", "toSide": "right", "label": "No → Continue (dashed)", "toEnd": "arrow" },
    { "id": "e10001", "fromNode": "b1c2d3e4f5f70002", "fromSide": "right", "toNode": "b1c2d3e4f5f70003", "toSide": "left", "toEnd": "arrow" },
    { "id": "e10002", "fromNode": "b1c2d3e4f5f70003", "fromSide": "right", "toNode": "b1c2d3e4f5f70004", "toSide": "left", "toEnd": "arrow" },
    { "id": "e10003", "fromNode": "b1c2d3e4f5f70004", "fromSide": "right", "toNode": "b1c2d3e4f5f70005", "toSide": "left", "toEnd": "arrow" },
    { "id": "e10004", "fromNode": "b1c2d3e4f5f70005", "fromSide": "right", "toNode": "b1c2d3e4f5f70006", "toSide": "left", "toEnd": "arrow" },
    { "id": "e10005", "fromNode": "b1c2d3e4f5f70006", "fromSide": "right", "toNode": "b1c2d3e4f5f70009", "toSide": "left", "label": "Yes", "toEnd": "arrow" },
    { "id": "e10006", "fromNode": "b1c2d3e4f5f70006", "fromSide": "bottom", "toNode": "b1c2d3e4f5f70007", "toSide": "top", "label": "No → iterate", "toEnd": "arrow" },
    { "id": "e10007", "fromNode": "b1c2d3e4f5f70007", "fromSide": "right", "toNode": "b1c2d3e4f5f70002", "toSide": "left", "label": "Loop back → re-build", "toEnd": "arrow" },
    { "id": "e10008", "fromNode": "b1c2d3e4f5f70007", "fromSide": "bottom", "toNode": "b1c2d3e4f5f70008", "toSide": "top", "label": "Max 5 reached", "toEnd": "arrow" },
    { "id": "e10009", "fromNode": "b1c2d3e4f5f70009", "fromSide": "right", "toNode": "b1c2d3e4f5f70010", "toSide": "left", "toEnd": "arrow" }
  ]
}
